# ─── BACKEND ENVIRONMENT VARIABLES ───
# Managed PostgreSQL database URL (get this from Neon.tech or Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secureflow

# Secret key for signing JWT tokens (generate using: openssl rand -hex 32)
SECRET_KEY=secureflow-ultimate-token-secret-development-key-phrase
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Production settings
DEBUG=False
LOG_LEVEL=INFO

# Allowed CORS origins for the frontend app (JSON array)
CORS_ORIGINS=["https://your-app.vercel.app"]

# ─── FRONTEND ENVIRONMENT VARIABLES ───
# Public URL of the FastAPI backend app (used by React/Vite)
VITE_API_URL=https://your-backend-app.onrender.com/api/v1

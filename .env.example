# ─── BACKEND ENVIRONMENT VARIABLES ───
# Managed PostgreSQL database URL (get this from Neon.tech or Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secureflow

# Secret key for signing JWT tokens (generate using: openssl rand -hex 32)
SECRET_KEY=secureflow-ultimate-token-secret-development-key-phrase
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Production settings
DEBUG=False
LOG_LEVEL=INFO

# Allowed CORS origins for the frontend app (JSON array)
CORS_ORIGINS=["https://your-app.vercel.app"]

# ─── THIRD-PARTY INTEGRATION APIS ───
# Hugging Face API token for downloading AI models (from huggingface.co)
HF_TOKEN=hf_your_hugging_face_token_here

# AWS configuration (from AWS Console IAM section)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# Alerts & Notifications webhooks and keys
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
PAGERDUTY_API_KEY=pd_your_key_here

# ─── FRONTEND ENVIRONMENT VARIABLES ───
# Public URL of the FastAPI backend app (used by React/Vite)
VITE_API_URL=https://your-backend-app.onrender.com/api/v1
